<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cat"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#A7F3D0">


    <!-- Container for Herbal Spinner and its Label -->
    <Spinner
        android:id="@+id/category_spinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/corner"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.049"
        app:layout_goneMarginTop="50dp"
        />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/herbal_spinner_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/category_spinner"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Label for Herbal Spinner -->
        <TextView
            android:id="@+id/herbalcategory"
            android:layout_width="410dp"
            android:layout_height="29dp"
            android:background="@color/white"
            android:gravity="start|center_vertical"
            android:paddingStart="12dp"
            android:text="Select Herb"
            android:textSize="16sp"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/herbalspinner"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <!-- Herbal Spinner -->
        <Spinner
            android:id="@+id/herbalspinner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/corner"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/herbalcategory" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Container for Disease Spinner and its Label -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/herbal_spinner_container">

        <!-- Label for Disease Spinner -->

        <!-- Disease Spinner -->
        <TextView
            android:id="@+id/deseasecategory"
            android:layout_width="match_parent"
            android:layout_height="29dp"
            android:background="@color/white"
            android:gravity="start|center_vertical"
            android:paddingStart="12dp"
            android:text="Select Disease"
            android:textSize="16sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ImageView
        android:id="@+id/item_image"
        android:layout_width="373dp"
        android:layout_height="263dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.512"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.238"
        app:srcCompat="@drawable/corner" />

    <ScrollView
        android:id="@+id/svdef"
        android:layout_width="390dp"
        android:layout_height="343dp"
        android:gravity="center_horizontal"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/item_image">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/item_definition"
                android:layout_width="match_parent"
                android:layout_height="245dp"
                android:gravity="center_horizontal"
                android:text="TextView"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="15dp"
                android:textSize="25sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/title"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:gravity="start|center_horizontal"
                    android:text="TextView"
                    android:layout_marginStart="15dp"
                    android:textColor="@color/black"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:visibility="visible" />

                <ImageView
                    android:id="@+id/rec"
                    android:layout_width="match_parent"
                    android:layout_height="245dp"
                    android:contentDescription="1"
                    android:visibility="visible"
                    app:srcCompat="@drawable/corner" />

                <TextView
                    android:id="@+id/title2"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:gravity="start|center_vertical"
                    android:text="TextView"
                    android:layout_marginStart="15dp"
                    android:textColor="@color/black"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:visibility="visible" />

                <ImageView
                    android:id="@+id/rec2"
                    android:layout_width="match_parent"
                    android:layout_height="245dp"
                    android:contentDescription="1"
                    android:visibility="visible"
                    app:srcCompat="@drawable/corner" />

                <TextView
                    android:id="@+id/title3"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:layout_marginStart="15dp"
                    android:gravity="start|center_vertical"
                    android:text="TextView"
                    android:textColor="@color/black"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:visibility="visible" />

                <ImageView
                    android:id="@+id/rec3"
                    android:layout_width="match_parent"
                    android:layout_height="245dp"
                    android:contentDescription="1"
                    android:visibility="visible"
                    app:srcCompat="@drawable/corner" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>


    <ImageView
        android:id="@+id/category_background"
        android:layout_width="327dp"
        android:layout_height="260dp"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.498"
        app:srcCompat="@mipmap/ic_launcher_foreground"
        tools:visibility="visible" />

    <ImageView
        android:id="@+id/category_background2"
        android:layout_width="327dp"
        android:layout_height="260dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.498"
        app:srcCompat="@drawable/disease"
        tools:visibility="gone" />

    <Spinner
        android:id="@+id/deseasespinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:background="@drawable/corner"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/category_spinner" />


    <include
        android:id="@+id/included_panel"
        layout="@layout/universal_btn"
        android:layout_width="0dp"
        android:layout_height="81dp"
        android:layout_marginBottom="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>