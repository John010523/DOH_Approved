<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#A7F3D0">

    <!-- Herbal Name Title -->
    <TextView
        android:id="@+id/herbalcategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="35dp"
        android:gravity="center"
        android:text="Herbal Name"
        android:textColor="@color/black"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Main Herb Image -->
    <ImageView
        android:id="@+id/item_image"
        android:layout_width="0dp"
        android:layout_height="490dp"
        android:layout_margin="16dp"
        android:scaleType="centerCrop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/herbalcategory"
        app:srcCompat="@drawable/corner" />

    <!-- Details Container -->
    <ScrollView
        android:id="@+id/svdef"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="100dp"
        android:requiresFadingEdge="vertical"
        android:scrollbarThumbVertical="@android:color/black"
        android:scrollbars="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/item_image">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Disease Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Capable of Curing:"
                android:textColor="#065F46"
                android:textStyle="bold"
                android:textSize="18sp" />
            <TextView
                android:id="@+id/item_diseases"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:text="Disease List"
                android:textSize="16sp" />

            <!-- Definition Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Definition:"
                android:textColor="#065F46"
                android:textStyle="bold"
                android:textSize="18sp" />
            <TextView
                android:id="@+id/item_definition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:text="Herb Description"
                android:textSize="16sp" />

            <!-- Preparation Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preparation:"
                android:textColor="#065F46"
                android:textStyle="bold"
                android:textSize="18sp" />
            <TextView
                android:id="@+id/item_preparation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:text="How to prepare"
                android:textSize="16sp" />

            <!-- Safety Warning Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Safety Warning:"
                android:textColor="#991B1B"
                android:textStyle="bold"
                android:textSize="18sp" />
            <TextView
                android:id="@+id/item_warning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:text="Warnings here"
                android:textSize="16sp" />

            <!-- Location Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location:"
                android:textColor="#065F46"
                android:textStyle="bold"
                android:textSize="18sp" />
            <TextView
                android:id="@+id/item_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="30dp"
                android:text="Where to find"
                android:textSize="16sp" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation included -->
    <include
        android:id="@+id/included_panel"
        layout="@layout/universal_btn"
        android:layout_width="0dp"
        android:layout_height="81dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>